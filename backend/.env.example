# Core Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://127.0.0.1:5500,http://localhost:5500

# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017/antigravity_qms
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/antigravity_qms
MONGODB_URI=mongodb://localhost:27017/antigravity_qms

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_encryption_key_antigravity
JWT_EXPIRES_IN=7d

# Twilio SMS API Configuration
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Cloud API Configuration
WHATSAPP_TOKEN=EAAG...your_whatsapp_cloud_system_token
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERSION=v19.0

# SMTP / Email Notification Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=Antigravity Queue <noreply@antigravityqms.com>
